<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 全局放开明文 HTTP：校园内服务大量走裸 IP / 非 uwh 域名，按白名单维护成本太高，且本应用不上架。 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
